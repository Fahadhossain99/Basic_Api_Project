    {
      "name": "Admin Login",
      "item": [
        {
          "name": "Admin_Login",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "var url = \"http://localhost:5000\";\r",
                  "var Key = \"ROADTOSDET\";\r",
                  "\r",
                  "pm.collectionVariables.set(\"baseUrl\", url);\r",
                  "pm.collectionVariables.set(\"secretKey\", Key); // ✅ CORRECT"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();\r",
                  "pm.test(\"User can login Successfully\", function () {\r",
                  "    pm.expect(jsonData.message).to.eql(\"Login successful\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Status code is 200\" , function(){\r",
                  "    pm.response.to.have.status(200) \r",
                  "  }  );\r",
                  "\r",
                  "var token = jsonData.token;\r",
                  "pm.collectionVariables.set(\"adminToken\" , token)"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"email\": \"admin@dmoney.com\",\r\n  \"password\": \"1234\"\r\n}",
              "options": {
